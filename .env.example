# ============================================================
# Pages & Patterns — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git.

# ── Database (Required) ────────────────────────────────────
# PostgreSQL connection string.
# Recommended: Neon (https://neon.tech) — free tier works great,
# and has a first-party Vercel integration.
#
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Replit dev server only (not needed for Vercel) ─────────
# These are set automatically by Replit and are only required
# when running the dev server locally on Replit.
# PORT=3000
# BASE_PATH=/
