{
  "buildCommand": "pnpm --filter @workspace/library-portfolio run build",
  "outputDirectory": "artifacts/library-portfolio/dist/public",
  "functions": {
    "api/index.ts": {
      "runtime": "nodejs20.x",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
